---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Bechard Tech Solutions | Software Development & Turnkey Solutions",
	description = "Custom software development, mobile apps, and turnkey digital solutions. We build modern, scalable applications tailored to your business needs."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="author" content="Bechard Tech Solutions" />
		<meta name="theme-color" content="#0a0a1a" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	:root {
		/* Colors */
		--color-bg: #0a0a1a;
		--color-bg-alt: #0f0f2a;
		--color-surface: #161633;
		--color-surface-hover: #1e1e44;
		--color-border: rgba(99, 102, 241, 0.15);
		--color-border-hover: rgba(99, 102, 241, 0.35);
		--color-text: #e8e8f0;
		--color-text-muted: #9494b8;
		--color-text-subtle: #6a6a8e;
		--color-primary: #6366f1;
		--color-primary-light: #818cf8;
		--color-primary-glow: rgba(99, 102, 241, 0.25);
		--color-accent: #06b6d4;
		--color-accent-glow: rgba(6, 182, 212, 0.2);
		--color-gradient-start: #6366f1;
		--color-gradient-end: #06b6d4;

		/* Typography */
		--font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		--font-mono: 'JetBrains Mono', 'Fira Code', monospace;

		/* Spacing */
		--section-padding: 6rem 2rem;
		--container-max: 1200px;

		/* Transitions */
		--transition-fast: 150ms ease;
		--transition-base: 300ms ease;
		--transition-slow: 500ms ease;

		/* Radius */
		--radius-sm: 0.5rem;
		--radius-md: 0.75rem;
		--radius-lg: 1rem;
		--radius-xl: 1.5rem;
	}

	html {
		scroll-behavior: smooth;
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: var(--color-bg);
		color: var(--color-text);
		font-family: var(--font-sans);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		display: block;
	}

	::selection {
		background: var(--color-primary);
		color: white;
	}
</style>
